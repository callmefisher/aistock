PROJECT_NAME=选股池自动化系统
VERSION=1.0.0

DATABASE_URL=mysql+aiomysql://stock_user:stock_password@mysql:3306/stock_pool
DATABASE_URL_SYNC=mysql+pymysql://stock_user:stock_password@mysql:3306/stock_pool

REDIS_URL=redis://redis:6379/0

SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

SELENIUM_URL=http://selenium:4444/wd/hub

DATA_DIR=/app/data
EXCEL_DIR=/app/data/excel
LOGS_DIR=/app/data/logs
COOKIES_DIR=/app/data/cookies

OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=your-email@gmail.com
