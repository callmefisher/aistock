# Auto-detect text files
* text=auto

# Force LF line endings for shell scripts (critical on Windows)
*.sh text eol=lf

# macOS double-clickable scripts — must be LF. If Windows git converts
# to CRLF, the shebang becomes "#!/bin/bash\r" and execve fails.
*.command text eol=lf

# Force CRLF for Windows batch files - cmd.exe mis-parses LF-only .bat,
# producing errors like "'tlocal' is not recognized" from `setlocal`.
*.bat text eol=crlf
*.cmd text eol=crlf

# Force LF for Docker and compose files
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# .env files — critical: CRLF breaks env var parsing on Linux containers
.env text eol=lf
.env.example text eol=lf
.env.* text eol=lf
*.sql text eol=lf
